{
  "manifest_version": 3,
  "name": "AI-Bridge: Universal AI Analyst",
  "version": "3.1",
  "description": "Universal AI shortcuts (DS, C, G, X) for any website. Powered by DeepSeek, ChatGPT, Gemini, and Grok.",
  "permissions": [
    "storage",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
